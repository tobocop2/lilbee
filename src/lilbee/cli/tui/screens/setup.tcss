#setup-title {
    text-style: bold;
    text-align: center;
    padding: 1 0 0 0;
}

#setup-subtitle {
    text-align: center;
    color: $text-muted;
    padding: 0 0 1 0;
}

#setup-grid-container {
    height: 1fr;
    padding: 0 1;
}

#setup-footer {
    dock: bottom;
    height: auto;
    padding: 0 1;
}

#setup-chat-slot {
    width: 1fr;
    text-style: bold;
}

#setup-embed-slot {
    width: 1fr;
    text-style: bold;
}

#setup-download-size {
    width: auto;
    color: $text-muted;
}

#setup-action {
    margin: 0 1;
    width: 100%;
}

#setup-browse {
    margin: 0 1;
    width: 100%;
}

#setup-skip {
    margin: 0 1;
    width: 100%;
}

#setup-status {
    height: 1;
    padding: 0 1;
    color: $text-muted;
    display: none;
}

#setup-progress {
    height: 1;
    margin: 0 1;
    display: none;
}

SetupWizard.-downloading #setup-status {
    display: block;
}

SetupWizard.-downloading #setup-progress {
    display: block;
}

ModelCard.-selected {
    border-left: thick $success;
    background: $success 10%;
}

.section-heading {
    text-style: bold;
    color: $text-muted;
    padding: 1 1 0 2;
}

GridSelect {
    height: auto;
    padding: 0;
    margin: 0 1;
    grid-gutter: 1;
}
