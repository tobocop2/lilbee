{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "codesearch": "deny",
    "websearch": "deny",
    "webfetch": "deny",
    "read": "allow",
    "write": "allow",
    "edit": "allow",
    "bash": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "lilbee_*": "allow"
  },
  "mcp": {
    "lilbee": {
      "type": "local",
      "command": ["lilbee", "mcp"]
    }
  }
}
